# Claves de API — nunca versionar
API/
*.key
.env
.env.*

# macOS
.DS_Store

# Archivos temporales
*.tmp
~$*

# Research outputs generados (regenerables) — no versionar
Reportes/*
!Reportes/.gitkeep

# Memoria personal del agente (tesis y calibracion son del usuario)
Memoria/tesis/*
!Memoria/tesis/.gitkeep
Memoria/calibracion.md

# Datos personales del inversionista — privados de este fork.
# El perfil lleva capital, objetivos y tolerancia al riesgo reales, y la
# memoria acumula las tesis y errores de cada analisis. Este fork es
# publico, asi que nada de esto se versiona.
Perfil Inversionista/*
!Perfil Inversionista/.gitkeep
Memoria/MEMORIA.md
Memoria/errores.md
